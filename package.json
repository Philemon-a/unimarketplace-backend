{
    "name": "unimarketplace-backend",
    "version": "1.0.0",
    "description": "Backend API for University Marketplace - A platform for university students to buy and sell items within their campus community",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "jest --forceExit --detectOpenHandles",
        "test:watch": "jest --watch --forceExit --detectOpenHandles",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "marketplace",
        "university",
        "express",
        "typescript",
        "nodejs"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@supabase/supabase-js": "^2.95.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.10.5",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "eslint": "^8.56.0",
        "jest": "^30.3.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "supabase": "^2.76.15",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
